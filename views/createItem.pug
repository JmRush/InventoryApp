extends layout

block content 
    +navbar
    div(class="create-item-container" id="create-item-container")
        h1= "Create a new stock item"
        div(class="create-form")
            form(method="POST" action="/manga/create" enctype="multipart/form-data")
                input(type="hidden" name=csrfField value=csrfToken)
                div(class="title-autocomplete" id="title-autocomplete")
                    input(type="text" name="item_name" placeholder="Listing Title" id="manga-name-create" maxlength=150 autocomplete="off" required)
                input(type="text"   name="item_description" placeholder="Manga Description" id="manga-description-create" maxlength=1000 required)
                input(type="text"   name="item_categories"  placeholder="Manga Categories (comma-separated)" id="manga-categories-create" maxlength=1618 required)
                input(type="number" name="price"            placeholder='10.00' id="manga-price-create" min=10 max=1000000 step="0.01" required)
                input(type="number" name="number_in_stock"  placeholder='1' id="manga-stock-create" min=0 max=1000000 step=1 required)
                input(type="text"   name="item_publisher"   placeholder="Publisher Name" id="manga-publisher-create" maxlength=150 required)
                input(type="text"   name="item_author"      placeholder="Author Name" id="manga-author-create" maxlength=150 required)
                input(type='file'   name="item_picture"     placeholder="Item Picture" id="manga-picture-upload" accept=".jpg, .jpeg, .png" required)
                input(type="submit")
    script(src="/javascripts/api-autofill.js" defer)
