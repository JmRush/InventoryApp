# Copy to .env and fill in values.
# Generate admin hash + session secret with:
#   node scripts/set-admin-password.js "your-strong-password"

NODE_ENV=development
PORT=3000

# MongoDB connection string
DEV_MONGODB=mongodb+srv://USER:PASS@HOST/DB
# PROD_MONGODB=mongodb+srv://USER:PASS@HOST/DB

# Required auth settings (written by set-admin-password.js)
SESSION_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Production requires one trusted HTTPS reverse proxy (nginx, Render, Fly, etc.).
# Keep 0 for direct local development and use 1 in production.
TRUST_PROXY=0

# Absolute path for uploaded images. Public URL stays /data/uploads/...
# Local default: <project>/public/data/uploads
# Production example: /srv/invapp/uploads
# UPLOAD_DIR=/srv/invapp/uploads
